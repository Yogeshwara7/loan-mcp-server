# =========================================================================
# Microsoft Entra ID (Azure AD) - Client Credentials Flow
# =========================================================================
# Directory (tenant) ID of your Entra ID tenant.
TENANT_ID=00000000-0000-0000-0000-000000000000

# Application (client) ID of the App Registration.
CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client secret VALUE (not the secret ID) generated for the App Registration.
CLIENT_SECRET=your-client-secret-value

# =========================================================================
# Dataverse
# =========================================================================
# Base environment URL WITHOUT a trailing slash and WITHOUT the /api path.
# Example: https://yourorg.crm.dynamics.com
DATAVERSE_URL=https://yourorg.crm.dynamics.com

# =========================================================================
# Optional overrides (sane defaults are applied when omitted)
# =========================================================================
# Dataverse Web API version.
# DATAVERSE_API_VERSION=v9.2

# Plural entity SET name of the loan table (used in data paths).
# DATAVERSE_LOAN_TABLE=cr174_loanapplics

# Singular entity LOGICAL name of the loan table (used in metadata paths, e.g.
# resolving choice/option-set values for status filtering).
# DATAVERSE_LOAN_ENTITY=cr174_loanapplic

# "Officer Assigned" lookup: navigation property to $expand, the name column on
# the related record, and (for the getOfficer helper) the related entity set and
# its email column. Defaults target systemuser.
# OFFICER_NAV_PROPERTY=cr174_OfficerAssigned
# OFFICER_NAME_FIELD=fullname
# OFFICER_ENTITY_SET=systemusers
# OFFICER_EMAIL_FIELD=internalemailaddress

# HTTP request timeout in milliseconds (Dataverse calls).
# HTTP_TIMEOUT_MS=30000

# Log level: trace | debug | info | warn | error | fatal | silent
# LOG_LEVEL=info

# =========================================================================
# HTTP transport (only used by the Streamable HTTP entrypoint: npm run start:http)
# The stdio entrypoint (Claude Desktop) ignores these.
# =========================================================================
# Port and host to bind. Use 0.0.0.0 when hosting behind a proxy/tunnel.
# HTTP_PORT=3000
# HTTP_HOST=127.0.0.1

# Path the MCP endpoint is served on.
# MCP_HTTP_PATH=/mcp

# Shared secret required on HTTP requests via `x-api-key` or `Authorization:
# Bearer`. STRONGLY recommended before exposing the endpoint. If unset, the
# HTTP endpoint is UNAUTHENTICATED (a warning is logged).
# MCP_API_KEY=change-me-to-a-long-random-secret

# CORS Access-Control-Allow-Origin for the HTTP transport.
# MCP_CORS_ORIGIN=*
